# --- Server ---
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- LLM provider selection ---
# "echo" (stub, default), "anthropic" (Claude), or "openai".
# Auto-selects based on which API key is present when LLM_PROVIDER is unset.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=        # optional; overrides https://api.anthropic.com/
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_SYSTEM_PROMPT=You are a helpful AI assistant.
OPENAI_API_KEY=
OPENAI_BASE_URL=           # optional; overrides https://api.openai.com/v1/ — use for proxies or compatible APIs (e.g. Azure, local Ollama)
OPENAI_MODEL=gpt-4o
OPENAI_SYSTEM_PROMPT=You are a helpful AI assistant.

# --- Memory backend selection ---
# "memory" (in-process, default for local dev) or "greennode" (AgentBase).
# Auto-selects "greennode" when GREENNODE_MEMORY_ID and GREENNODE_CLIENT_ID are set.
MEMORY_BACKEND=

# --- GreenNode AgentBase (only needed when MEMORY_BACKEND=greennode) ---
GREENNODE_MEMORY_ID=
GREENNODE_MEMORY_NAMESPACE=default
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
# Optional overrides (sane defaults baked in):
# GREENNODE_MEMORY_BASE_URL=https://agentbase.api.vngcloud.vn/memory
# GREENNODE_OAUTH2_TOKEN_URL=https://iam.api.vngcloud.vn/accounts-api/v2/auth/token
